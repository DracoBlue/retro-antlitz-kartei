{
  "name": "@retro-antlitz-kartei/generator",
  "version": "0.2.0",
  "description": "Retro pixel-art, full-body avatar generator — deterministic from a seed, rendered to canvas.",
  "license": "MIT",
  "author": "DracoBlue",
  "homepage": "https://github.com/DracoBlue/retro-antlitz-kartei/tree/main/packages/generator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DracoBlue/retro-antlitz-kartei.git",
    "directory": "packages/generator"
  },
  "keywords": [
    "avatar",
    "pixel-art",
    "generator",
    "canvas",
    "retro",
    "dicebear",
    "seed"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
