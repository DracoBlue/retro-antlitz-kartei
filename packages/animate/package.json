{
  "name": "@retro-antlitz-kartei/animate",
  "version": "0.1.1",
  "description": "Combat-arena pose animation for retro-antlitz-kartei avatars (idle, walk, attack, block, hit, win).",
  "license": "MIT",
  "author": "DracoBlue",
  "homepage": "https://github.com/DracoBlue/retro-antlitz-kartei/tree/main/packages/animate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DracoBlue/retro-antlitz-kartei.git",
    "directory": "packages/animate"
  },
  "keywords": [
    "avatar",
    "pixel-art",
    "animation",
    "canvas",
    "sprite",
    "retro"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@retro-antlitz-kartei/generator": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
